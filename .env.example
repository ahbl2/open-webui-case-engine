# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# Detective stack local dev (Vite on 3001 + uvicorn on 8080), prefer an explicit allow list:
# CORS_ALLOW_ORIGIN='http://localhost:3001;http://localhost:8080'
# For LAN access (e.g. testing from another machine or a tablet on the same network), add the
# actual browser origin — the LAN IP+port the browser uses for the Vite frontend.
# Include BOTH http and https variants when switching between non-secure and secure-context tests:
# CORS_ALLOW_ORIGIN='http://localhost:3001;https://localhost:3001;http://localhost:8080;http://<LAN-IP>:3001;https://<LAN-IP>:3001'
#
# WARNING — inline env var overrides: if you pass CORS_ALLOW_ORIGIN in the shell command that
# starts uvicorn (e.g. CORS_ALLOW_ORIGIN='...' python -m uvicorn ...), that value overrides this
# file and any value set by dev.sh. Omitting the LAN origin causes Engine.IO polling POST to
# return 400 even though polling GET succeeds (browsers send Origin on POST, not on same-origin GET).
# Prefer using dev.sh without an inline CORS_ALLOW_ORIGIN override.
CORS_ALLOW_ORIGIN='*'

# Optional: extra origins allowed for Socket.IO only (semicolon-separated). When CORS_ALLOW_ORIGIN
# is a fixed list (not '*'), add UI origins that hit the backend on another host:port (e.g. LAN).
# SOCKETIO_CORS_EXTRA_ORIGINS=http://192.168.1.194:3001

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# --- Vite dev proxy (read at dev server startup; not the browser Socket.IO URL) ---
# Port where Python uvicorn listens. Vite forwards /api, /ws, /ollama, etc. to 127.0.0.1:this port.
PUBLIC_WEBUI_BACKEND_PORT=8080
# WEBUI_BACKEND_PORT=8080

# Optional: hide Case Engine structured-notes preview UI even when the server enables it (P34-21). Unset = follow server GET /health structured_notes_enabled only.
# PUBLIC_STRUCTURED_NOTES_ENABLED=0

# P75-03 — Wave 2 DS app shell frame (`DetectiveAppShellFrame`). Unset = on. Set to 0/false/off/no to rollback to pre–P75-02 main column (sidebar unchanged).
# PUBLIC_DETECTIVE_WAVE2_APP_SHELL=0

# P76-03 — Wave 3 case workspace shell frame (`ds-case-shell*` + `data-region` in `case/[id]/+layout`). Unset = on.
# Independent of PUBLIC_DETECTIVE_WAVE2_APP_SHELL. Set to 0/false/off/no to rollback to pre–P76-02 case root/body/canvas/rail classes.
# PUBLIC_DETECTIVE_WAVE3_CASE_SHELL=0

# --- Browser Socket.IO (PUBLIC_* is exposed to the client) ---
# LONG-TERM DEFAULT: leave PUBLIC_WS_URL unset.
#   Socket.IO uses the same origin as the page (Vite :3001); Vite proxies /ws → Python :8080.
#   Setting PUBLIC_WS_URL to the wrong host/port (e.g. :3000, or :8080 backend) breaks chat / realtime.
# If you must override, set PUBLIC_WS_URL to the exact browser origin only (scheme + host + port of the Vite page), e.g.:
#   PUBLIC_WS_URL=https://192.168.1.194:3001
# Never set PUBLIC_WS_URL to the uvicorn port in the standard stack.
# PUBLIC_WS_URL=http://127.0.0.1:8080

# --- HTTPS for Vite dev (LAN dictation / secure context / HTTPS parity) ---
#
# Trusted (no browser cert warning): mkcert — run once: `mkcert -install`, then:
#   ./scripts/dev-tls-mkcert.sh
#   # optional: ./scripts/dev-tls-mkcert.sh 192.168.x.x
# DEV_HTTPS_KEY_FILE=.../certs/mkcert-dev-key.pem
# DEV_HTTPS_CERT_FILE=.../certs/mkcert-dev-cert.pem
#
# Self-signed (browser shows ERR_CERT_AUTHORITY_INVALID until you proceed / add exception):
#   ./scripts/dev-tls-cert.sh
#   # optional: ./scripts/dev-tls-cert.sh 192.168.x.x
# DEV_HTTPS_KEY_FILE=.../certs/dev-key.pem
# DEV_HTTPS_CERT_FILE=.../certs/dev-cert.pem
#
# Restart: npm run dev -- --host 0.0.0.0
# Open: https://localhost:3001 (and https://<LAN-IP>:3001 if in SAN)
# If CORS_ALLOW_ORIGIN is a fixed list (not '*'), add every https://<host>:3001 you use.
# Case Engine 3010 / Python 8080 stay HTTP; Vite terminates TLS and proxies.